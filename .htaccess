# GÜNALP — sunucu kuralları (yalnızca gerçek sunucuda etkilidir; GitHub Pages yok sayar)

# Tek resmi adres: http'yi ve www'suz adresi kalıcı (301) olarak
# https://www.gunalp.com.tr'ye yönlendir — Google iki ayrı site sanmasın.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteCond %{HTTP_HOST} !^localhost [NC]
  RewriteRule ^(.*)$ https://www.gunalp.com.tr/$1 [L,R=301]

  # Eski sitenin (Joomla) adresleri: Google'da hâlâ kayıtlılar ama artık 404 veriyorlar.
  # Ziyaretçi ve Google boşluğa düşmesin diye kalıcı (301) olarak yeni sayfalara gönder.
  RewriteRule ^en(/.*)?$ https://www.gunalp.com.tr/ [L,R=301]
  RewriteRule ^arb(/.*)?$ https://www.gunalp.com.tr/ar/ [L,R=301]
  RewriteRule ^index\.php$ https://www.gunalp.com.tr/ [L,R=301,QSD]
</IfModule>

# Olmayan bir sayfa açılırsa sunucu hatası yerine kendi şık 404 sayfamız görünsün
ErrorDocument 404 /404.html

# Amaç: HTML sayfaları her zaman tazelensin (tarayıcı eski sayfayı göstermesin),
# görsel/CSS/JS gibi statik varlıklar uzun önbellekte kalsın (adları ya da ?v= değişince yenilenir).
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate, max-age=0"
  </FilesMatch>
  <FilesMatch "\.(jpg|jpeg|png|webp|gif|svg|ico|woff2|woff|ttf|css|js|mp4|webm)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

# Güvenlik: yönetim/gizli dosyalar sunucuda dışarıdan açılamasın (yanlışlıkla yüklenirse)
<FilesMatch "^(admin\.php|admin-config\.php|ceviri-config\.php|ceviri-baglam\.md|ceviri-durum\.json|router\.php)$">
  Require all denied
</FilesMatch>
